{% extends 'admin/base.html.twig' %}

{% block title %}Gestion des établissements — Admin{% endblock %}

{% block body %}
{% for label, messages in app.flashes %}
    {% for message in messages %}
        <div class="alert alert-{{ label == 'success' ? 'success' : 'danger' }} alert-dismissible fade show" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}
{% endfor %}

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">🏫 Tous les établissements</h5>
        <a href="{{ path('app_admin_etablissement_new') }}" class="btn btn-primary btn-sm">+ Ajouter</a>
    </div>
    <div class="card-body">
        <table class="table table-hover">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Nom</th>
                    <th>Ville</th>
                    <th>Type</th>
                    <th>Contact</th>
                    <th>Filières</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for etab in etablissements %}
                <tr>
                    <td>{{ etab.id }}</td>
                    <td><strong>{{ etab.nom }}</strong></td>
                    <td>{{ etab.ville }}</td>
                    <td>{{ etab.type ?? '—' }}</td>
                    <td>{{ etab.contact ?? '—' }}</td>
                    <td><span class="badge bg-info text-dark">{{ etab.filieres|length }}</span></td>
                    <td>
                        <a href="{{ path('app_admin_etablissement_show', {id: etab.id}) }}" class="btn btn-sm btn-outline-secondary">👁 Voir</a>
                        <a href="{{ path('app_admin_etablissement_edit', {id: etab.id}) }}" class="btn btn-sm btn-outline-primary">✏️ Modifier</a>
                        <form method="post" action="{{ path('app_admin_etablissement_delete', {id: etab.id}) }}" class="d-inline"
                              onsubmit="return confirm('Supprimer cet établissement ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ etab.id) }}">
                            <button class="btn btn-sm btn-outline-danger">🗑 Supprimer</button>
                        </form>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="7" class="text-center text-muted py-4">Aucun établissement enregistré.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
