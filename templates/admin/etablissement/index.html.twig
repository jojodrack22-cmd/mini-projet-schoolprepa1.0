{% extends 'admin/base.html.twig' %}

{% block title %}Gestion des établissements — Admin{% endblock %}

{% block body %}
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">🏫 Tous les établissements</h5>
        <a href="#" class="btn btn-primary btn-sm">+ Ajouter</a>
    </div>
    <div class="card-body">
        <table class="table table-hover">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Nom</th>
                    <th>Ville</th>
                    <th>Type</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for etab in etablissements %}
                <tr>
                    <td>{{ etab.id }}</td>
                    <td>{{ etab.nom }}</td>
                    <td>{{ etab.ville }}</td>
                    <td>{{ etab.type }}</td>
                    <td>
                        <a href="#" class="btn btn-sm btn-outline-primary">✏️ Modifier</a>
                        <a href="#" class="btn btn-sm btn-outline-danger">🗑 Supprimer</a>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}