{% extends 'admin/base.html.twig' %}

{% block title %}Gestion des filières — Admin{% endblock %}

{% block body %}
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">📚 Toutes les filières</h5>
        <a href="#" class="btn btn-primary btn-sm">+ Ajouter</a>
    </div>
    <div class="card-body">
        <table class="table table-hover">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Nom</th>
                    <th>Durée</th>
                    <th>Débouchés</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for filiere in filieres %}
                <tr>
                    <td>{{ filiere.id }}</td>
                    <td>{{ filiere.nom }}</td>
                    <td>{{ filiere.duree }}</td>
                    <td>{{ filiere.debouches }}</td>
                    <td>
                        <a href="#" class="btn btn-sm btn-outline-primary">✏️ Modifier</a>
                        <a href="#" class="btn btn-sm btn-outline-danger">🗑 Supprimer</a>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}