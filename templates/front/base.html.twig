<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}SchoolPrepar{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .navbar-brand { font-size: 1.5rem; }
        .hero { background: linear-gradient(135deg, #0d6efd, #0dcaf0); color: white; padding: 80px 0; }
        .card:hover { transform: translateY(-5px); transition: 0.3s; box-shadow: 0 8px 25px rgba(0,0,0,0.1); }
        footer { background: #1a1a2e; color: #aaa; }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body class="bg-light">

{% include 'front/partials/nav.html.twig' %}

<main>
    {% block body %}{% endblock %}
</main>

{% include 'front/partials/footer.html.twig' %}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
{% block javascripts %}{% endblock %}
</body>
</html>